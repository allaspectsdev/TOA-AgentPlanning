    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.39.0",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@toa/tsconfig": "workspace:*",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
